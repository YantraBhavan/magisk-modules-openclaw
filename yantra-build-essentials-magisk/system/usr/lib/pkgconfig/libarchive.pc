prefix=/data/data/com.termux/files/usr
exec_prefix=${prefix}
libdir=/data/data/com.termux/files/usr/lib
includedir=/data/data/com.termux/files/usr/include

Name: libarchive
Description: library that can create and read several streaming archive formats
Version: 3.8.5
Cflags: -I${includedir}
Cflags.private: -DLIBARCHIVE_STATIC
Libs: -L${libdir} -larchive
Libs.private: -lcrypto -lbz2  -lz /data/data/com.termux/files/usr/lib/libiconv.so -L/data/data/com.termux/files/usr/lib -llzma -L/data/data/com.termux/files/usr/lib -lxml2
Requires.private: libcrypto
